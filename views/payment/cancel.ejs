<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= pageTitle %></title>
    <link rel="stylesheet" href="/main.css">
</head>
<body>
    <%- include('../includes/navbar.ejs') %>

    <main class="payment-result">
        <section class="payment-result-card">
            <p class="checkout-kicker">Checkout canceled</p>
            <h1>No worries, the donation was not completed.</h1>
            <p>
                <%= typeof message !== 'undefined' ? message : 'You can return to the support page whenever you are ready.' %>
            </p>
            <div class="payment-result-actions">
                <a href="/checkout" class="blog-card-btn">Try Again</a>
                <a href="/blogs" class="blog-card-btn payment-secondary-btn">Read Blogs</a>
            </div>
        </section>
    </main>

    <%- include('../includes/footer') %>
</body>
</html>

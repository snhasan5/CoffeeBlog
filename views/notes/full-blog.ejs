<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= pagetitle %></title>
    <link rel="stylesheet" href="/main.css">
</head>
<body>

    <%- include('../includes/navbar.ejs') %>

    <%
    const THEMES = {
        ESPRESSO: { bg: '#4B3621', text: '#f5efe6', titleColor: '#f5efe6', btnBg: '#D7B899', btnText: '#4b3621' },
        MOCHA:    { bg: '#8B5E3C', text: '#f5efe6', titleColor: '#f5efe6', btnBg: '#4B3621', btnText: '#f5efe6' },
        LATTE:    { bg: '#D7B899', text: '#4b3621', titleColor: '#4b2907', btnBg: '#4B3621', btnText: '#f5efe6' }
    };
    const theme = THEMES[blog.color] || THEMES.LATTE;
    %>

    <main class="blog-details-wrapper">
        <div class="blog-details-container" style="background: <%= theme.bg %>">

            <h1 class="blog-details-title" style="color: <%= theme.titleColor %>">
                <%= blog.title %>
            </h1>

            <div class="blog-details-meta" style="color: <%= theme.text %>">
                <p><strong>Author:</strong> <%= blog.author %></p>

                <% if (blog.userId && blog.userId.email) { %>
                    <p><strong>Email:</strong> <%= blog.userId.email %></p>
                <% } %>

                <p>
                    <strong>Created:</strong>
                    <%= blog.createdAt ? blog.createdAt.toString() : "Not available" %>
                </p>
            </div>

            <% if (blog.imageUrl) { %>
                <img
                    src="<%= blog.imageUrl %>"
                    alt="<%= blog.title %>"
                    class="blog-details-image"
                >
            <% } %>

            <div class="blog-details-content" style="color: <%= theme.text %>">
                <p><%= blog.content %></p>
            </div>
            <div style="margin-top: 25px">
                <a href="/blogs" class="blog-card-btn"
                   style="background: <%= theme.btnBg %>; color: <%= theme.btnText %>">
                    ← Back to Blogs
                </a>
            </div>
        </div>
    </main>

</body>
</html>
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= pageTitle %></title>
    <link rel="stylesheet" href="/main.css">
</head>
<body>

    <%- include('../includes/navbar.ejs') %>

    <section class="hero">
        <h1>☕ Welcome to CoffeeBlog</h1>
        <p>
            A cozy corner of the internet where thoughts, stories,
            coding notes, and coffee-fueled ideas come together.
            Grab a cup of coffee and explore interesting articles,
            personal notes, and inspirations.
        </p>
    </section>

    <section class="posts">
        <div class="card">
            <h3>Morning Brew</h3>
            <p>
                Discover how a simple cup of coffee can boost creativity
                and help kickstart your day.
            </p>
        </div>

        <div class="card">
            <h3>Coding & Coffee</h3>
            <p>
                Programming sessions feel better with a warm cup beside
                your keyboard. Read tips and experiences.
            </p>
        </div>

        <div class="card">
            <h3>Coffee House Stories</h3>
            <p>
                Explore stories, ideas, and conversations inspired by
                local cafés around the world.
            </p>
        </div>
    </section>

    <%- include('../includes/footer') %>

</body>
</html>

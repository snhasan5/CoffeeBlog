<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= pageTitle %></title>
    <link rel="stylesheet" href="/main.css">
</head>
<body>
<%- include("../includes/navbar") %>

<section class="hero">
    <h1>My Blogs</h1>
    <p>Read, edit, and manage your blogs here.</p>
</section>

<section class="notes-container">
    <%
    const THEMES = {
        ESPRESSO: { bg: '#3e2723', text: '#f5efe6', btnBg: '#D7B899', btnText: '#3e2723' },
        MOCHA:    { bg: '#8B5E3C', text: '#f5efe6', btnBg: '#3e2723', btnText: '#f5efe6' },
        LATTE:    { bg: '#D7B899', text: '#3e2723', btnBg: '#3e2723', btnText: '#f5efe6' }
    };
    %>

    <% blogs.forEach((blog) => {
        const theme = THEMES[blog.color] || THEMES.LATTE;
    %>
        <div class="blog-card" style="background: <%= theme.bg %>">
            <div class="blog-card-content">
                <h3 class="blog-card-title" style="color: <%= theme.text %>"><%= blog.title %></h3>

                <% if (blog.imageUrl) { %>
                    <img src="/<%= blog.imageUrl %>" alt="<%= blog.title %>" class="blog-card-image">
                <% } else { %>
                    <div class="blog-card-image blog-card-image-placeholder">No image</div>
                <% } %>

                <div class="blog-actions">
                    <a
                        href="/edit-blog/<%= blog._id %>?edit=true"
                        class="blog-card-btn"
                        style="background: <%= theme.btnBg %>; color: <%= theme.btnText %>"
                    >
                        Edit
                    </a>

                    <form
                        action="/delete-blog/<%= blog._id %>"
                        method="POST"
                    >
                        <input type="hidden" name="_csrf" value="<%= _csrf %>">

                        <button
                            type="submit"
                            class="blog-card-btn"
                            style="background: <%= theme.btnBg %>; color: <%= theme.btnText %>"
                            onclick="return confirm('Delete this blog?')"
                        >
                            Delete
                        </button>
                    </form>
                </div>

                <p class="blog-card-author" style="color: <%= theme.text %>">
                    By <strong><%= blog.author %></strong>
                </p>
            </div>
        </div>
    <% }) %>
</section>

<div style="text-align:center; margin:40px;">
    <a href="/add-blog" class="blog-card-btn">
        Create New Blog
    </a>
</div>

<%- include('../includes/footer') %>

</body>
</html>

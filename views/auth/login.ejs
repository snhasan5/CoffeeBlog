<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= pageTitle %></title>
    <link rel="stylesheet" href="/main.css">
</head>
<body>

<%- include("../includes/navbar") %>

<div class="auth-container">
    <form action="/login" method="POST" class="auth-form">

        <h2>Login</h2>
        <% if(errorMessage){ %>
            <div class="error-message">* <%= errorMessage %></div>
            <% } %>
        <input
            class="<%=  validationErrors.find((e)=>{ return e.path === 'email'}) ? 'invalid' : ''%>"

            type="email"
            name="email"
            placeholder="Enter your email"
            value="<%= enteredValue.email%>"
            required
        >

        <input
            class="<%=  validationErrors.find((e)=>{ return e.path === 'password'}) ? 'invalid' : ''%>"
            type="password"
            name="password"
            placeholder="Enter your password"
            value="<%= enteredValue.password%>"
            required
        >
        <input type="hidden" name="_csrf" value="<%= _csrf %>">
        <a href="/reset" style="color:black; padding-left: 3px;">Forgot Password?</a>
        <button type="submit" class="blog-card-btn">
            Login
        </button>
    </form>
</div>

<%- include('../includes/footer') %>

</body>
</html>